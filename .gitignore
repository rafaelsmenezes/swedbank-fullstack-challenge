# ============================================
# SwedenBank Fullstack Challenge — .gitignore
# ============================================

# ──────────────────────────────────────────
# BACKEND (Spring Boot + Gradle)
# ──────────────────────────────────────────

# Gradle
.gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/

# Spring Boot artifacts (generated — do not commit)
HELP.md
*.jar
*.war
*.ear

# Ensure Gradle wrapper jar is never ignored
!**/gradle/wrapper/gradle-wrapper.jar

# Logs
*.log
logs/

# IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr
out/
!**/src/main/**/out/
!**/src/test/**/out/

# Eclipse / STS
.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache
bin/
!**/src/main/**/bin/
!**/src/test/**/bin/

# NetBeans
/nbproject/private/
/nbbuild/
/nbdist/
/.nb-gradle/

# ──────────────────────────────────────────
# FRONTEND (Angular)
# ──────────────────────────────────────────

# Compiled output
dist/
tmp/
out-tsc/
bazel-out/

# Node
node_modules/
npm-debug.log*
yarn-error.log*

# Angular cache
.angular/

# Test coverage
coverage/

# SASS cache
.sass-cache/

# Misc
/connect.lock
/libpeerconnection.log
testem.log
/typings
__screenshots__/

# ──────────────────────────────────────────
# DOCKER
# ──────────────────────────────────────────

# Docker volumes and override files
docker-compose.override.yml
.docker/

# ──────────────────────────────────────────
# IDEs & EDITORS
# ──────────────────────────────────────────

# VS Code
.vscode/
.history/

# ──────────────────────────────────────────
# OPERATING SYSTEM
# ──────────────────────────────────────────

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

# ──────────────────────────────────────────
# SECURITY — never commit
# ──────────────────────────────────────────

.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.jks
application-prod.properties
application-secrets.properties