# Git
.git/
.gitignore

# IDE
.idea/
*.iml
*.ipr
*.iws

# OS
.DS_Store
Thumbs.db

# Documentation
*.md
!README.md

# Docker (prevent recursive context issues)
Dockerfile*
.dockerignore

# Test/helper scripts (not needed in image)
api-*.sh
*.sh

# CI / misc
.github/
.vscode/
*.log
